# Número de WhatsApp en formato internacional, solo dígitos.
# Ejemplo de formato para México: 52 + número de 10 dígitos. Déjalo vacío hasta validarlo.
NEXT_PUBLIC_WHATSAPP_NUMBER=

# URL canónica absoluta. Usa la URL local durante desarrollo y reemplázala al desplegar.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Analítica no esencial desactivada por defecto. Solo "true" activa la solicitud.
NEXT_PUBLIC_ANALYTICS_ENABLED=false

# ID real de Google Analytics. Déjalo vacío si la analítica está desactivada.
NEXT_PUBLIC_ANALYTICS_MEASUREMENT_ID=
